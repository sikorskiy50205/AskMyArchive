{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=askmyarchive;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Llm": {
    "Chat": {
      "BaseUrl": "https://api.deepseek.com/v1",
      "ApiKey": "",
      "Model": "deepseek-v4-flash"
    },
    "Embeddings": {
      "BaseUrl": "http://localhost:11434/v1",
      "ApiKey": "",
      "Model": "bge-m3",
      "Dimensions": 1024
    }
  },
  "Storage": {
    "RootPath": "data/uploads"
  },
  "Jwt": {
    "Issuer": "AskMyArchive",
    "Audience": "AskMyArchive",
    "Key": "dev-only-secret-change-me-0123456789abcdef",
    "LifetimeMinutes": 15
  },
  "RefreshToken": {
    "LifetimeDays": 30,
    "CookieName": "askmyarchive_refresh",
    "SecureCookie": false,
    "SameSite": "Lax"
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "Email": {
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "UseSsl": false,
    "FromAddress": "noreply@askmyarchive.local",
    "FromName": "AskMyArchive",
    "LinkBaseUrl": "http://localhost:3000"
  },
  "Database": {
    "AutoMigrate": true
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
